---
import type { Form as Props } from '~/types';
import Button from '~/components/ui/Button.astro';

const { inputs, textarea, disclaimer, button = 'Contact us', description = '' } = Astro.props;
---

<form id="contact-form">
  {
    inputs &&
      inputs.map(
        ({ type = 'text', name, label = '', autocomplete = 'on', placeholder = '', options, required }) =>
          name && (
            <div class="mb-6">
              {label && (
                <label for={name} class="block text-xs font-mono font-bold text-bond-navy mb-2 tracking-widest uppercase">
                  {label}
                </label>
              )}
              {type === 'select' && options ? (
                <select
                  name={name}
                  id={name}
                  required={required}
                  class="py-3 px-4 block w-full text-md border border-bond-navy/20 bg-white focus:outline-none focus:ring-1 focus:ring-bond-yellow-main focus:border-bond-yellow-main transition-colors rounded-none"
                >
                  {options.map((opt) => (
                    <option value={opt.value}>{opt.label}</option>
                  ))}
                </select>
              ) : (
                <input
                  type={type}
                  name={name}
                  id={name}
                  autocomplete={autocomplete}
                  placeholder={placeholder}
                  required={required}
                  class="py-3 px-4 block w-full text-md border border-bond-navy/20 bg-white placeholder:text-gray-400 focus:outline-none focus:ring-1 focus:ring-bond-yellow-main focus:border-bond-yellow-main transition-colors rounded-none"
                />
              )}
            </div>
          )
      )
  }

  {
    textarea && (
      <div>
        <label for="textarea" class="block text-xs font-mono font-bold text-bond-navy mb-2 tracking-widest uppercase">
          {textarea.label}
        </label>
        <textarea
          id="textarea"
          name={textarea.name ? textarea.name : 'message'}
          rows={textarea.rows ? textarea.rows : 4}
          placeholder={textarea.placeholder}
          class="py-3 px-4 block w-full text-md border border-bond-navy/20 bg-white placeholder:text-gray-400 focus:outline-none focus:ring-1 focus:ring-bond-yellow-main focus:border-bond-yellow-main transition-colors rounded-none"
        />
      </div>
    )
  }

  {
    disclaimer && (
      <div class="mt-6 flex items-start">
        <div class="flex mt-0.5">
          <input
            id="disclaimer"
            name="disclaimer"
            type="checkbox"
            class="cursor-pointer mt-1 py-3 px-4 block w-full text-md border border-bond-navy/20 bg-white focus:outline-none focus:ring-1 focus:ring-bond-yellow-main focus:border-bond-yellow-main rounded-none"
          />
        </div>
        <div class="ml-3">
          <label for="disclaimer" class="cursor-pointer select-none text-sm text-bond-text-sub">
            {disclaimer.label}
          </label>
        </div>
      </div>
    )
  }

  {
    button && (
      <div class="mt-10 grid">
        <Button variant="primary" type="submit" id="submit-btn">
          {button}
        </Button>
      </div>
    )
  }

  <!-- 送信状態表示 -->
  <div id="form-status" class="mt-4 hidden">
    <div id="form-loading" class="hidden text-center py-3 text-bond-text-sub text-sm">
      <svg class="animate-spin inline-block w-5 h-5 mr-2 text-bond-navy" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      送信中...
    </div>
    <div id="form-success" class="hidden text-center py-4 px-6 bg-green-50 border border-green-200 text-green-800 text-sm">
      お問い合わせありがとうございます。確認メールをお送りしましたのでご確認ください。
    </div>
    <div id="form-error" class="hidden text-center py-4 px-6 bg-red-50 border border-red-200 text-red-800 text-sm">
    </div>
  </div>

  {
    description && (
      <div class="mt-3 text-center">
        <p class="text-sm text-bond-text-sub">{description}</p>
      </div>
    )
  }
</form>
