---
import type { HTMLAttributes } from 'astro/types';
import { findImage } from '~/utils/images';
import {
  getImagesOptimized,
  astroAssetsOptimizer,
  unpicOptimizer,
  isUnpicCompatible,
  type ImageProps,
} from '~/utils/images-optimization';

type Props = ImageProps;
type ImageType = {
  src: string;
  attributes: HTMLAttributes<'img'>;
};

const props = Astro.props;

if (props.alt === undefined || props.alt === null) {
  throw new Error();
}

if (typeof props.width === 'string') {
  props.width = parseInt(props.width);
}

if (typeof props.height === 'string') {
  props.height = parseInt(props.height);
}

if (!props.loading) {
  props.loading = 'lazy';
}

if (!props.decoding) {
  props.decoding = 'async';
}

const _image = await findImage(props.src);

let image: ImageType | undefined = undefined;
let isLocalAsset = false;

if (
  typeof _image === 'string' &&
  (_image.startsWith('http://') || _image.startsWith('https://')) &&
  isUnpicCompatible(_image)
) {
  image = await getImagesOptimized(_image, props, unpicOptimizer);
} else if (_image) {
  isLocalAsset = true;
  image = await getImagesOptimized(_image, props, astroAssetsOptimizer);
}

// SEO/LLMO spec IMG-01: ローカルアセットはAVIF→WebPの順で配信し、元形式をフォールバックにする
let avifSrcset: string | undefined;
let webpSrcset: string | undefined;
if (image && isLocalAsset && _image) {
  avifSrcset = (await getImagesOptimized(_image, { ...props, format: 'avif' }, astroAssetsOptimizer)).attributes.srcset as
    | string
    | undefined;
  webpSrcset = (await getImagesOptimized(_image, { ...props, format: 'webp' }, astroAssetsOptimizer)).attributes.srcset as
    | string
    | undefined;
}
---

{
  !image ? (
    <Fragment />
  ) : avifSrcset || webpSrcset ? (
    <picture class="contents">
      {avifSrcset && <source type="image/avif" srcset={avifSrcset} sizes={image.attributes.sizes} />}
      {webpSrcset && <source type="image/webp" srcset={webpSrcset} sizes={image.attributes.sizes} />}
      <img src={image.src} crossorigin="anonymous" referrerpolicy="no-referrer" {...image.attributes} />
    </picture>
  ) : (
    <img src={image.src} crossorigin="anonymous" referrerpolicy="no-referrer" {...image.attributes} />
  )
}
