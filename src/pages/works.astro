---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import StructuredData from '~/components/common/StructuredData.astro';
import Breadcrumb from '~/components/common/Breadcrumb.astro';
import { Icon } from 'astro-icon/components';
import heroWorks from '~/assets/images/hero-works.png';

const metadata = {
  title: '実績一覧',
  description: '合同会社ぼんどの実績・事例ページ。地域事業者さまとのプロジェクト事例は順次公開してまいります。',
};

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: '実績・事例', url: '/works' },
];
---

<Layout metadata={metadata}>
  <StructuredData breadcrumbs={breadcrumbs} />
  <Breadcrumb items={breadcrumbs} />

  <!-- ヒーローセクション -->
  <Hero2
    tagline="Works & Case Studies"
    image={{ src: heroWorks, alt: 'Works Hero' }}
    actions={[
      {
        text: 'お問い合わせはこちら',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">
      実績・事例
    </Fragment>

    <Fragment slot="subtitle">
      地域事業者さまとのプロジェクト事例は<br />
      順次公開してまいります
    </Fragment>
  </Hero2>

  <!-- 準備中 -->
  <section class="py-20 lg:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-bond-yellow-main/10 mb-8">
        <Icon name="tabler:pencil" class="w-10 h-10 text-bond-yellow-deep" />
      </div>

      <h2 class="text-3xl md:text-4xl font-bold text-bond-navy mb-6">
        実績は準備中です
      </h2>

      <p class="text-lg text-bond-text-sub leading-relaxed mb-4">
        合同会社ぼんどは2025年11月に設立したばかりの会社です。
      </p>
      <p class="text-lg text-bond-text-sub leading-relaxed">
        現在進行中のプロジェクトの成果がまとまり次第、<br class="hidden sm:inline" />
        お客さまの許可をいただいたうえで、こちらに掲載してまいります。
      </p>
    </div>
  </section>

  <!-- 開発デモ -->
  <section class="py-16 lg:py-24 bg-bond-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold text-bond-navy mb-4">
          実際に触れる開発デモ
        </h2>
        <p class="text-lg text-bond-text-sub leading-relaxed">
          お客さまの事例とは別に、ぼんどが自社開発したツールを<br class="hidden sm:inline" />
          デモとして公開しています。実際に操作してお試しいただけます。
        </p>
      </div>

      <div class="bg-bond-surface border border-bond-navy/10 rounded-2xl p-8 md:p-10 shadow-sm">
        <div class="flex items-start gap-4 mb-6">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-bond-yellow-main/15 shrink-0">
            <Icon name="tabler:checklist" class="w-6 h-6 text-bond-yellow-deep" />
          </div>
          <div>
            <h3 class="text-xl md:text-2xl font-bold text-bond-navy mb-1">
              診断型リード獲得ツール
            </h3>
            <p class="text-sm text-bond-text-sub">自社開発デモ｜3分診断でサイト訪問者を見込み客リストに変える仕組み</p>
          </div>
        </div>

        <p class="text-bond-text-sub leading-relaxed mb-6">
          Webサイトに設置する「3分でわかる診断」です。訪問者が10問に答えると、結果を見る手前で連絡先を入力する流れになっており、回答スコアとあわせて見込み客リストが自動で蓄積されます。採用力・AI活用度・バックオフィス効率化の3ジャンルを体験できますが、設問を差し替えるだけで業種・テーマを問わず展開できます。
        </p>

        <ul class="flex flex-wrap gap-2 mb-8">
          <li class="text-sm px-3 py-1 rounded-full bg-bond-yellow-main/10 text-bond-navy">🤝 採用力診断</li>
          <li class="text-sm px-3 py-1 rounded-full bg-bond-yellow-main/10 text-bond-navy">🤖 AI活用度診断</li>
          <li class="text-sm px-3 py-1 rounded-full bg-bond-yellow-main/10 text-bond-navy">📊 バックオフィス効率化診断</li>
        </ul>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/demo/diagnosis/" class="btn-primary" target="_blank" rel="noopener">
            デモを試してみる
          </a>
          <a href="/contact" class="btn-secondary">
            導入について相談する
          </a>
        </div>
      </div>

      <p class="text-sm text-bond-text-sub text-center mt-6">
        ※ こちらはお客さまの導入実績ではなく、ぼんどが自社開発したデモンストレーションです。
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-bond-navy mb-6">
        ご相談をお待ちしています
      </h2>
      <p class="text-lg text-bond-text-sub mb-8">
        地域ビジネスの成長を、私たちがサポートします。<br />
        まずは無料相談から始めてみませんか？
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-primary">
          無料相談を申し込む
        </a>
        <a href="/services" class="btn-secondary">
          サービス一覧を見る
        </a>
      </div>
    </div>
  </section>
</Layout>
