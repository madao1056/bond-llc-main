---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import StructuredData from '~/components/common/StructuredData.astro';
import Breadcrumb from '~/components/common/Breadcrumb.astro';
import { Icon } from 'astro-icon/components';
import heroWorks from '~/assets/images/hero-works.png';

const metadata = {
  title: '実績一覧',
  description: '合同会社ぼんどの実績・事例ページ。飲食店さまのお弁当Web予約システム構築など、地域事業者さまとのプロジェクト事例をご紹介します。',
};

const breadcrumbs = [
  { name: 'ホーム', url: '/' },
  { name: '実績・事例', url: '/works' },
];
---

<Layout metadata={metadata}>
  <StructuredData breadcrumbs={breadcrumbs} />
  <Breadcrumb items={breadcrumbs} />

  <!-- ヒーローセクション -->
  <Hero2
    tagline="Works & Case Studies"
    image={{ src: heroWorks, alt: 'Works Hero' }}
    actions={[
      {
        text: 'お問い合わせはこちら',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">
      実績・事例
    </Fragment>

    <Fragment slot="subtitle">
      地域事業者さまとのプロジェクト事例を<br />
      ご紹介します
    </Fragment>
  </Hero2>

  <!-- 導入事例 -->
  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold text-bond-navy mb-4">
          導入事例
        </h2>
        <p class="text-lg text-bond-text-sub leading-relaxed">
          お客さまの許可をいただいたうえで掲載しています。
        </p>
      </div>

      <div class="bg-bond-surface border border-bond-navy/10 rounded-2xl p-8 md:p-10 shadow-sm">
        <div class="flex items-start gap-4 mb-6">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-bond-yellow-main/15 shrink-0">
            <Icon name="tabler:tools-kitchen-2" class="w-6 h-6 text-bond-yellow-deep" />
          </div>
          <div>
            <h3 class="text-xl md:text-2xl font-bold text-bond-navy mb-1">
              お弁当のWeb予約システム構築
            </h3>
            <p class="text-sm text-bond-text-sub">
              <a href="https://www.instagram.com/souzaiyaraisin/" target="_blank" rel="noopener" class="text-bond-yellow-deep font-medium hover:underline">惣菜屋レザン</a> さま｜飲食店
            </p>
          </div>
        </div>

        <p class="text-bond-navy font-bold text-lg leading-relaxed mb-8">
          インスタ・電話・LINEに分散していた予約窓口を一本化し、「漏れ」を防ぐ
        </p>

        <div class="mb-8">
          <h4 class="flex items-center gap-2 text-lg font-bold text-bond-navy mb-3">
            <Icon name="tabler:alert-circle" class="w-5 h-5 text-bond-yellow-deep" />
            課題
          </h4>
          <p class="text-bond-text-sub leading-relaxed">
            お弁当の予約が、インスタグラムのメッセージ・電話・LINEと複数の窓口に分かれて届いていました。それぞれ確認する場所が違うため、営業と並行して全部を追いかける必要があり、今後注文が増えていったときに「見落とし・返信漏れ」が起きるリスクを抱えていました。また、口頭やメッセージでのやり取りは、注文内容や合計金額の控えも手作業になりがちでした。
          </p>
        </div>

        <div class="mb-8">
          <h4 class="flex items-center gap-2 text-lg font-bold text-bond-navy mb-3">
            <Icon name="tabler:bulb" class="w-5 h-5 text-bond-yellow-deep" />
            解決
          </h4>
          <p class="text-bond-text-sub leading-relaxed">
            予約の入口を1つにまとめる、スマホから24時間注文できるWeb予約フォームを構築しました。設計で大切にしたのは「お店側の運用を変えないこと」。メニューの追加・価格変更・販売停止は、お店が使い慣れた表を1行直すだけでフォームに自動反映されます。予約が入ると注文内容と合計金額が自動で記録され、お客さまには確認メールが自動送信。当日予約の締切時間や定休日の受付停止も、すべて自動で制御されます。
          </p>
        </div>

        <div>
          <h4 class="flex items-center gap-2 text-lg font-bold text-bond-navy mb-3">
            <Icon name="tabler:trophy" class="w-5 h-5 text-bond-yellow-deep" />
            結果
          </h4>
          <ul class="space-y-3">
            <li class="flex items-start gap-3 text-bond-text-sub leading-relaxed">
              <Icon name="tabler:check" class="w-5 h-5 text-bond-yellow-deep shrink-0 mt-1" />
              予約が1か所に集まる体制になり、複数アプリを見回る負担と見落としリスクを解消
            </li>
            <li class="flex items-start gap-3 text-bond-text-sub leading-relaxed">
              <Icon name="tabler:check" class="w-5 h-5 text-bond-yellow-deep shrink-0 mt-1" />
              注文が増えても運用が変わらない、「これから」に耐える受付の仕組みに
            </li>
            <li class="flex items-start gap-3 text-bond-text-sub leading-relaxed">
              <Icon name="tabler:check" class="w-5 h-5 text-bond-yellow-deep shrink-0 mt-1" />
              注文内容と金額が自動で記録されるため、聞き間違い・計算ミスの心配がない
            </li>
            <li class="flex items-start gap-3 text-bond-text-sub leading-relaxed">
              <Icon name="tabler:check" class="w-5 h-5 text-bond-yellow-deep shrink-0 mt-1" />
              メニュー改定は表を直すだけ。ITの専門知識ゼロで日々の運用が完結
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 開発デモ -->
  <section class="py-16 lg:py-24 bg-bond-background">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold text-bond-navy mb-4">
          実際に触れる開発デモ
        </h2>
        <p class="text-lg text-bond-text-sub leading-relaxed">
          お客さまの事例とは別に、ぼんどが自社開発したツールを<br class="hidden sm:inline" />
          デモとして公開しています。実際に操作してお試しいただけます。
        </p>
      </div>

      <div class="bg-bond-surface border border-bond-navy/10 rounded-2xl p-8 md:p-10 shadow-sm">
        <div class="flex items-start gap-4 mb-6">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-bond-yellow-main/15 shrink-0">
            <Icon name="tabler:checklist" class="w-6 h-6 text-bond-yellow-deep" />
          </div>
          <div>
            <h3 class="text-xl md:text-2xl font-bold text-bond-navy mb-1">
              診断型リード獲得ツール
            </h3>
            <p class="text-sm text-bond-text-sub">自社開発デモ｜3分診断でサイト訪問者を見込み客リストに変える仕組み</p>
          </div>
        </div>

        <p class="text-bond-text-sub leading-relaxed mb-6">
          Webサイトに設置する「3分でわかる診断」です。訪問者が10問に答えると、結果を見る手前で連絡先を入力する流れになっており、回答スコアとあわせて見込み客リストが自動で蓄積されます。採用力・AI活用度・バックオフィス効率化の3ジャンルを体験できますが、設問を差し替えるだけで業種・テーマを問わず展開できます。
        </p>

        <ul class="flex flex-wrap gap-2 mb-8">
          <li class="text-sm px-3 py-1 rounded-full bg-bond-yellow-main/10 text-bond-navy">🤝 採用力診断</li>
          <li class="text-sm px-3 py-1 rounded-full bg-bond-yellow-main/10 text-bond-navy">🤖 AI活用度診断</li>
          <li class="text-sm px-3 py-1 rounded-full bg-bond-yellow-main/10 text-bond-navy">📊 バックオフィス効率化診断</li>
        </ul>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/demo/diagnosis/" class="btn-primary" target="_blank" rel="noopener">
            デモを試してみる
          </a>
          <a href="/contact" class="btn-secondary">
            導入について相談する
          </a>
        </div>
      </div>

      <p class="text-sm text-bond-text-sub text-center mt-6">
        ※ こちらはお客さまの導入実績ではなく、ぼんどが自社開発したデモンストレーションです。
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-bond-navy mb-6">
        ご相談をお待ちしています
      </h2>
      <p class="text-lg text-bond-text-sub mb-8">
        地域ビジネスの成長を、私たちがサポートします。<br />
        まずは無料相談から始めてみませんか？
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-primary">
          無料相談を申し込む
        </a>
        <a href="/services" class="btn-secondary">
          サービス一覧を見る
        </a>
      </div>
    </div>
  </section>
</Layout>
